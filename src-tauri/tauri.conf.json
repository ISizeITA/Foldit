{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foldit",
  "version": "0.1.0",
  "identifier": "app.foldit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Foldit",
        "width": 1100,
        "height": 720,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0b0d10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "ISize",
    "copyright": "© ISize · Roldano Laurenza",
    "shortDescription": "Foldit — transparent NTFS compression for games and apps",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ISizeITA/Foldit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzMjQzRTdDRUE3RENGOTUKUldTVnozM3FmRDRrRTZNQlBXUTdyRXZPU0daTjFSNUNZSGQyaWtqVGxnanVHaHc3bGdQeHcxSDAK"
    }
  }
}
